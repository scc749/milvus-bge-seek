APP_ENV=dev
LOG_LEVEL=INFO
ENABLE_LANGSMITH=false
LANGSMITH_PROJECT=milvus-bge-seek
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEMPERATURE=0.0
DEEPSEEK_MAX_RETRIES=2

# Embeddings
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_NORMALIZE=true
# For BGE-M3 keep this empty by default.
EMBEDDING_QUERY_INSTRUCTION=
HUGGINGFACEHUB_API_TOKEN=
HF_ENDPOINT=https://hf-mirror.com

# Reranker
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANK_TOP_N=4

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=
MILVUS_DB_NAME=default
MILVUS_COLLECTION=rag_documents
MILVUS_PRIMARY_FIELD=pk
MILVUS_TEXT_FIELD=text
MILVUS_VECTOR_FIELD=vector
MILVUS_METADATA_FIELD=metadata
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=AUTOINDEX
# Optional JSON blobs if you need custom tuning.
MILVUS_INDEX_PARAMS=
MILVUS_SEARCH_PARAMS=

# Retrieval
RETRIEVAL_TOP_K=8
SCORE_THRESHOLD=0.0

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Source Storage
SOURCE_STORAGE_BACKEND=local
SOURCE_STORAGE_ROOT=data/source_files
SOURCE_STORAGE_BUCKET=rag-source-files
SOURCE_STORAGE_PREFIX=documents
SOURCE_STORAGE_MINIO_ENDPOINT=http://localhost:9090
SOURCE_STORAGE_MINIO_ACCESS_KEY=minioadmin
SOURCE_STORAGE_MINIO_SECRET_KEY=minioadmin
SOURCE_STORAGE_MINIO_SECURE=false

# PostgreSQL (reserved for the next architecture stage)
POSTGRES_DSN=postgresql://postgres:postgres@localhost:5432/rag_app
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rag_app
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=public
